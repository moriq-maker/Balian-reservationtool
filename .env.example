# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env はGit管理対象外です(.gitignoreで除外済み)。
# cp .env.example .env

# Supabase PostgreSQL接続文字列(Supabaseプロジェクト作成後、Connection Stringから取得)
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Supabaseクライアント接続用(Supabaseダッシュボード > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="xxxxxxxx"

# サーバー側の管理操作用(絶対にクライアントへ露出させない)
SUPABASE_SERVICE_ROLE_KEY="xxxxxxxx"

# 管理者セッションの署名鍵(ランダムな長い文字列を生成して設定。例: openssl rand -base64 32)
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# 一般スタッフセッションの署名鍵(ランダムな長い文字列を生成して設定。ADMIN_SESSION_SECRETとは別の値にする)
STAFF_SESSION_SECRET="change-me-to-a-long-random-string"

# Vercel Cronからのリクエスト検証用シークレット
CRON_SECRET="change-me-to-a-long-random-string"

# 開発環境のシード投入時のみ使用(本番のパスワード・アクセスコードは別途変更すること)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me-please"
SEED_STAFF_ACCESS_CODE="123456"
